{
    "env": {
        "browser": true,
        "es2021": true
    },
    "extends": [
        "google",
				"prettier"
    ],
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "plugins": [
        "@typescript-eslint"
    ],
    "rules": {
        "indent": ["error", "tab"],
        "no-tabs": 0,
				"new-cap": 0,
				"max-len": "off"
		}
}
